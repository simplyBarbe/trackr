@using Trackr.Api.Models

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                @if (_currencyError is not null)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">@_currencyError</MudAlert>
                }

                <MudTextField T="string"
                              Label="Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              MaxLength="100"
                              Immediate="true"
                              @bind-Value="_name" />

                <MudSelect T="AccountType"
                           Label="Type"
                           Variant="Variant.Outlined"
                           Value="_type"
                           ValueChanged="@OnTypeChanged">
                    <MudSelectItem T="AccountType" Value="AccountType.Checking">Checking</MudSelectItem>
                    <MudSelectItem T="AccountType" Value="AccountType.Savings">Savings</MudSelectItem>
                    <MudSelectItem T="AccountType" Value="AccountType.Cash">Cash</MudSelectItem>
                    <MudSelectItem T="AccountType" Value="AccountType.CreditCard">Credit card</MudSelectItem>
                </MudSelect>

                <MudSelect T="AccountColor"
                           Label="Color"
                           Variant="Variant.Outlined"
                           @bind-Value="_color">
                    @foreach (var color in Enum.GetValues<AccountColor>())
                    {
                        <MudSelectItem T="AccountColor" Value="@color">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span style="display:inline-block;width:1rem;height:1rem;border-radius:50%;@AccountCardStyles.GetCardStyle(color)"></span>
                                <span>@color</span>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudTextField T="string"
                              Label="Currency"
                              Variant="Variant.Outlined"
                              Required="true"
                              MaxLength="3"
                              Immediate="true"
                              Style="text-transform: uppercase;"
                              @bind-Value="_currency" />

                <MudNumericField T="decimal"
                                 Label="Initial balance"
                                 Variant="Variant.Outlined"
                                 Step="@(0.01m)"
                                 Format="N2"
                                 @bind-Value="_initialBalance" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync">
            @SubmitText
        </MudButton>
    </DialogActions>
</MudDialog>
