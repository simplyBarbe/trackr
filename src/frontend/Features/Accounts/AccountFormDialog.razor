@using Trackr.Api.Models

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudTextField T="string"
                              Label="Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              MaxLength="100"
                              Immediate="true"
                              @bind-Value="_name" />

                <MudSelect T="AccountType"
                           Label="Type"
                           Variant="Variant.Outlined"
                           Value="_type"
                           ValueChanged="@OnTypeChanged">
                    @foreach (var type in Enum.GetValues<AccountType>())
                    {
                        <MudSelectItem T="AccountType" Value="@type">@AccountTypeFormat.GetLabel(type)</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="AccountColor"
                           Label="Color"
                           Variant="Variant.Outlined"
                           @bind-Value="_color">
                    @foreach (var color in Enum.GetValues<AccountColor>())
                    {
                        <MudSelectItem T="AccountColor" Value="@color">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span style="@AccountCardStyles.GetSwatchStyle(color)"></span>
                                <span>@color</span>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField T="decimal"
                                 Label="Initial balance"
                                 Variant="Variant.Outlined"
                                 Step="@(0.01m)"
                                 Format="N2"
                                 @bind-Value="_initialBalance" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync">
            @SubmitText
        </MudButton>
    </DialogActions>
</MudDialog>
