@page "/accounts"

<PageTitle>Accounts</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Accounts</MudText>

@if (_accountsQuery.IsLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else
{
    @if (_accountsQuery.IsError)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_accountsQuery.Error</MudAlert>
    }

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Spacing="2"
              Class="mb-4"
              Style="flex-wrap: wrap;">
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@_mutation.IsPending"
                   OnClick="OpenCreateDialogAsync">
            New account
        </MudButton>

        <MudSelect T="string"
                   Label="Category"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="min-width: 14rem;"
                   Disabled="@(_categoriesQuery.IsLoading || _categoryFilterLoading)"
                   Value="_categoryIdFilter"
                   ValueChanged="OnCategoryFilterChanged">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @if (_categoriesQuery.HasData)
            {
                @foreach (var category in _categoriesQuery.Data!)
                {
                    <MudSelectItem T="string" Value="@(category.Id ?? "")">@category.Name</MudSelectItem>
                }
            }
        </MudSelect>
        @if (_categoriesQuery.IsFetching || _categoryFilterLoading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        }
        @if (_categoriesQuery.IsError)
        {
            <MudText Typo="Typo.caption" Color="Color.Error">@_categoriesQuery.Error</MudText>
        }

        <MudCheckBox T="bool"
                     Value="@_includeArchived"
                     Label="Include archived"
                     Dense="true"
                     ValueChanged="@OnIncludeArchivedChanged"/>
    </MudStack>

    @if (_accountsQuery.IsFetching)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }

    @if (!_accountsQuery.IsError && _accountsQuery.Data is not null)
    {
        @if (DisplayedAccounts.Count == 0)
        {
            <MudText>No accounts found.</MudText>
        }
        else
        {
            <MudTable Items="@DisplayedAccounts"
                      Hover="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Currency</MudTh>
                    <MudTh>Initial balance</MudTh>
                    <MudTh>Balance</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Archived</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Type">@(context.Type?.ToString() ?? "")</MudTd>
                    <MudTd DataLabel="Currency">@(context.Currency ?? "")</MudTd>
                    <MudTd DataLabel="Initial balance">@context.InitialBalance</MudTd>
                    <MudTd DataLabel="Balance">@context.Balance</MudTd>
                    <MudTd DataLabel="Created">@FormatCreatedAt(context.CreatedAt)</MudTd>
                    <MudTd DataLabel="Archived">
                        @(context.IsArchived switch { true => "Yes", false => "No", _ => "" })
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="@(_mutation.IsPending || context.IsArchived == true)"
                                       OnClick="@(() => OpenEditDialogAsync(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
}
