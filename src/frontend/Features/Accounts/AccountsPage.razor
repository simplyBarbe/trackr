@page "/accounts"

<PageTitle>Accounts</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Accounts</MudText>

@if (_query.IsLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else
{
    @if (_query.IsError)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_query.Error</MudAlert>
    }

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Spacing="2"
              Class="mb-4"
              Style="flex-wrap: wrap;">
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@_mutation.IsPending"
                   OnClick="OpenCreateDialogAsync">
            New account
        </MudButton>

        <MudSelect T="string"
                   Label="Type"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="min-width: 12rem;"
                   Value="_typeQuery"
                   ValueChanged="@OnTypeQueryChanged">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Checking")">Checking</MudSelectItem>
            <MudSelectItem T="string" Value="@("Savings")">Savings</MudSelectItem>
            <MudSelectItem T="string" Value="@("Cash")">Cash</MudSelectItem>
            <MudSelectItem T="string" Value="@("CreditCard")">Credit card</MudSelectItem>
        </MudSelect>

        <MudTextField T="string"
                      Label="Name contains"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Style="min-width: 14rem;"
                      Immediate="true"
                      @bind-Value="_nameDraft"
                      OnBlur="@ApplyNameFilterOnBlur"
                      @onkeydown="OnNameFilterKeyDown" />

        <MudCheckBox T="bool"
                     Value="@_includeArchived"
                     Label="Include archived"
                     Dense="true"
                     ValueChanged="@OnIncludeArchivedChanged"/>
    </MudStack>

    @if (_query.IsFetching)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }

    @if (!_query.IsError && _query.Data is not null)
    {
        @if (_query.Data.Count == 0)
        {
            <MudText>No accounts found.</MudText>
        }
        else
        {
            <MudTable Items="@_query.Data"
                      Hover="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Currency</MudTh>
                    <MudTh>Initial balance</MudTh>
                    <MudTh>Balance</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Archived</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Type">@(context.Type?.ToString() ?? "")</MudTd>
                    <MudTd DataLabel="Currency">@(context.Currency ?? "")</MudTd>
                    <MudTd DataLabel="Initial balance">@context.InitialBalance</MudTd>
                    <MudTd DataLabel="Balance">@context.Balance</MudTd>
                    <MudTd DataLabel="Created">@FormatCreatedAt(context.CreatedAt)</MudTd>
                    <MudTd DataLabel="Archived">
                        @(context.IsArchived switch { true => "Yes", false => "No", _ => "" })
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="@(_mutation.IsPending || context.IsArchived == true)"
                                       OnClick="@(() => OpenEditDialogAsync(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
}
