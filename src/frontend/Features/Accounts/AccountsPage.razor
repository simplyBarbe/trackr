@page "/accounts"
@using frontend.Features.Shared
@using Trackr.Api.Models

<PageTitle>Accounts</PageTitle>

<div class="trackr-page-header">
    <div>
        <span class="trackr-page-badge">Manage</span>
        <MudText Typo="Typo.h4" Style="font-weight: 600; letter-spacing: -0.02em;">Accounts</MudText>
    </div>
</div>

@if (_query.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_query.Error</MudAlert>
}

<div class="trackr-toolbar mb-4">
    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               Disabled="@_mutation.IsPending"
               OnClick="OpenCreateDialogAsync">
        New account
    </MudButton>

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Type"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_typeQuery"
                   ValueChanged="@OnTypeQueryChanged">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Checking")">Checking</MudSelectItem>
            <MudSelectItem T="string" Value="@("Savings")">Savings</MudSelectItem>
            <MudSelectItem T="string" Value="@("Cash")">Cash</MudSelectItem>
            <MudSelectItem T="string" Value="@("CreditCard")">Credit card</MudSelectItem>
        </MudSelect>
    </div>

    <div class="trackr-filter-field trackr-filter-field--wide">
        <MudTextField T="string"
                      Label="Name contains"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      @bind-Value="_nameDraft"
                      OnBlur="@ApplyNameFilterOnBlur"
                      @onkeydown="OnNameFilterKeyDown" />
    </div>

    <MudCheckBox T="bool"
                 Value="@_includeArchived"
                 Label="Include archived"
                 Dense="true"
                 ValueChanged="@OnIncludeArchivedChanged"/>
</div>

<MudTable T="AccountResponse"
          @ref="_table"
          @key="_tableVersion"
          ServerData="LoadServerDataAsync"
          RowsPerPage="50"
          Hover="true"
          Striped="true"
          Breakpoint="Breakpoint.Sm"
          Class="trackr-table">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Type</MudTh>
        <MudTh Style="text-align: right;">Initial balance</MudTh>
        <MudTh Style="text-align: right;">Balance</MudTh>
        <MudTh>Created</MudTh>
        <MudTh>Archived</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Type">@(context.Type?.ToString() ?? "")</MudTd>
        <MudTd DataLabel="Initial balance" Style="text-align: right;" Class="font-mono-numbers">
            @MoneyFormat.Format(context.InitialBalance)
        </MudTd>
        <MudTd DataLabel="Balance" Style="text-align: right;" Class="font-mono-numbers">
            @MoneyFormat.Format(context.Balance)
        </MudTd>
        <MudTd DataLabel="Created">@FormatCreatedAt(context.CreatedAt)</MudTd>
        <MudTd DataLabel="Archived">
            @(context.IsArchived switch { true => "Yes", false => "No", _ => "" })
        </MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_mutation.IsPending || context.IsArchived == true)"
                           OnClick="@(() => OpenEditDialogAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
