@page "/recurring-transactions"
@using Trackr.Api.Models
@using frontend.Features.Shared

<PageTitle>Recurring</PageTitle>

<div class="trackr-page-header">
    <div>
        <span class="trackr-page-badge">Automate</span>
        <MudText Typo="Typo.h4" Style="font-weight: 600; letter-spacing: -0.02em;">Recurring transactions</MudText>
        <MudText Typo="Typo.body2" Class="mt-1 mud-text-secondary">
            Transactions are created automatically on the due date (UTC).
        </MudText>
    </div>
    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               Disabled="@(_saving || !CanMutate)"
               OnClick="OpenCreateDialogAsync">
        New recurring
    </MudButton>
</div>

@if (_accountsLoading || _categoriesLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" Color="Color.Primary" />
}

@if (_accountsError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_accountsError</MudAlert>
}

<div class="trackr-toolbar mb-4">
    <div class="trackr-filter-field">
        <MudSelect T="bool?"
                   Label="Status"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_activeFilterDraft"
                   ValueChanged="@OnActiveFilterChanged"
                   Clearable="true">
            <MudSelectItem T="bool?" Value="@((bool?)null)">All</MudSelectItem>
            <MudSelectItem T="bool?" Value="@((bool?)true)">Active</MudSelectItem>
            <MudSelectItem T="bool?" Value="@((bool?)false)">Paused</MudSelectItem>
        </MudSelect>
    </div>
</div>

<RecurringTransactionsTableSection Filters="_listFilters"
                                   RefreshVersion="_refreshVersion"
                                   CanEdit="CanMutate"
                                   Saving="_saving"
                                   OnEdit="OpenEditDialogAsync"
                                   OnGenerateNow="GenerateNowAsync"
                                   OnToggleActive="ToggleActiveAsync"
                                   OnArchive="ArchiveAsync" />
