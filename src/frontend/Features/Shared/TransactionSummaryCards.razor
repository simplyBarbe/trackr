@using Trackr.Api.Models

<MudGrid Class="mb-4" Spacing="2">
    <MudItem xs="12" md="4">
        <div class="trackr-metric-tile trackr-metric-tile--featured pa-5">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Net savings</MudText>
            @if (IsInitialLoading)
            {
                <div class="trackr-shimmer" style="height: 2.5rem; width: 70%;"></div>
            }
            else
            {
                <MudText Typo="Typo.h4"
                         Class="font-mono-numbers"
                         Color="@GetNetSavingsColor()"
                         Style="font-weight: 600;">
                    @MoneyFormat.Format(NetSavings)
                </MudText>
            }
        </div>
    </MudItem>
    <MudItem xs="6" sm="6" md="2">
        <div class="trackr-metric-tile trackr-metric-tile--income pa-4" style="height: 100%;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Income</MudText>
            @if (IsInitialLoading)
            {
                <div class="trackr-shimmer" style="height: 1.75rem; width: 80%;"></div>
            }
            else
            {
                <MudText Typo="Typo.h6" Class="font-mono-numbers" Color="Color.Success" Style="font-weight: 600;">
                    @MoneyFormat.Format(Summary.TotalIncome)
                </MudText>
            }
        </div>
    </MudItem>
    <MudItem xs="6" sm="6" md="2">
        <div class="trackr-metric-tile trackr-metric-tile--essential pa-4" style="height: 100%;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Essential</MudText>
            @if (IsInitialLoading)
            {
                <div class="trackr-shimmer" style="height: 1.75rem; width: 80%;"></div>
            }
            else
            {
                <MudText Typo="Typo.h6" Class="font-mono-numbers" Color="Color.Error" Style="font-weight: 600;">
                    @MoneyFormat.Format(Summary.TotalEssentialExpense)
                </MudText>
            }
        </div>
    </MudItem>
    <MudItem xs="6" sm="6" md="2">
        <div class="trackr-metric-tile trackr-metric-tile--important pa-4" style="height: 100%;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Important</MudText>
            @if (IsInitialLoading)
            {
                <div class="trackr-shimmer" style="height: 1.75rem; width: 80%;"></div>
            }
            else
            {
                <MudText Typo="Typo.h6" Class="font-mono-numbers" Color="Color.Warning" Style="font-weight: 600;">
                    @MoneyFormat.Format(Summary.TotalImportantExpense)
                </MudText>
            }
        </div>
    </MudItem>
    <MudItem xs="6" sm="6" md="2">
        <div class="trackr-metric-tile trackr-metric-tile--discretionary pa-4" style="height: 100%;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Discretionary</MudText>
            @if (IsInitialLoading)
            {
                <div class="trackr-shimmer" style="height: 1.75rem; width: 80%;"></div>
            }
            else
            {
                <MudText Typo="Typo.h6" Class="font-mono-numbers" Style="font-weight: 600;">
                    @MoneyFormat.Format(Summary.TotalDiscretionaryExpense)
                </MudText>
            }
        </div>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public GetTransactionSummaryResponse Summary { get; set; } = null!;

    [Parameter]
    public bool IsInitialLoading { get; set; }

    private decimal NetSavings
    {
        get
        {
            var income = Summary.TotalIncome ?? 0m;
            var expenses = (Summary.TotalEssentialExpense ?? 0m)
                + (Summary.TotalImportantExpense ?? 0m)
                + (Summary.TotalDiscretionaryExpense ?? 0m);
            return income - expenses;
        }
    }

    private Color GetNetSavingsColor() =>
        NetSavings >= 0 ? Color.Success : Color.Error;
}
