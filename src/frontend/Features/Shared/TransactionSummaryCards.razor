@using frontend.Infrastructure
@using Trackr.Api.Models

<MudGrid Class="mb-4" Spacing="2">
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Income</MudText>
                @if (SummaryQuery.IsLoading && !SummaryQuery.HasData)
                {
                    <MudProgressLinear Indeterminate="true" Class="mt-2" />
                }
                else
                {
                    <MudText Typo="Typo.h5" Color="Color.Success">
                        @MoneyFormat.Format(SummaryQuery.Data?.TotalIncome)
                    </MudText>
                    @if (SummaryQuery.IsFetching)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-2" />
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Essential</MudText>
                @if (SummaryQuery.IsLoading && !SummaryQuery.HasData)
                {
                    <MudProgressLinear Indeterminate="true" Class="mt-2" />
                }
                else
                {
                    <MudText Typo="Typo.h5" Color="Color.Error">
                        @MoneyFormat.Format(SummaryQuery.Data?.TotalEssentialExpense)
                    </MudText>
                    @if (SummaryQuery.IsFetching)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-2" />
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Important</MudText>
                @if (SummaryQuery.IsLoading && !SummaryQuery.HasData)
                {
                    <MudProgressLinear Indeterminate="true" Class="mt-2" />
                }
                else
                {
                    <MudText Typo="Typo.h5" Color="Color.Warning">
                        @MoneyFormat.Format(SummaryQuery.Data?.TotalImportantExpense)
                    </MudText>
                    @if (SummaryQuery.IsFetching)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-2" />
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Discretionary</MudText>
                @if (SummaryQuery.IsLoading && !SummaryQuery.HasData)
                {
                    <MudProgressLinear Indeterminate="true" Class="mt-2" />
                }
                else
                {
                    <MudText Typo="Typo.h5">
                        @MoneyFormat.Format(SummaryQuery.Data?.TotalDiscretionaryExpense)
                    </MudText>
                    @if (SummaryQuery.IsFetching)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-2" />
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public QueryState<GetTransactionSummaryResponse> SummaryQuery { get; set; } = null!;
}
