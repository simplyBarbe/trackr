@page "/categories"
@using Trackr.Api.Models
@using frontend.Features.Shared

<PageTitle>Categories</PageTitle>

<div class="trackr-page-header">
    <div>
        <span class="trackr-page-badge">Manage</span>
        <MudText Typo="Typo.h4" Style="font-weight: 600; letter-spacing: -0.02em;">Categories</MudText>
    </div>
</div>

@if (_query.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_query.Error</MudAlert>
}

<div class="trackr-toolbar mb-4">
    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               Disabled="@_mutation.IsPending"
               OnClick="OpenCreateDialogAsync">
        New category
    </MudButton>

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Kind"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_kindQuery"
                   ValueChanged="@OnKindQueryChanged">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Income")">Income</MudSelectItem>
            <MudSelectItem T="string" Value="@("Expense")">Expense</MudSelectItem>
        </MudSelect>
    </div>

    <div class="trackr-filter-field trackr-filter-field--wide">
        <MudTextField T="string"
                      Label="Name contains"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      @bind-Value="_nameDraft"
                      OnBlur="@ApplyNameFilterOnBlur"
                      @onkeydown="OnNameFilterKeyDown" />
    </div>

    <MudCheckBox T="bool"
                 Value="@_includeArchived"
                 Label="Include archived"
                 Dense="true"
                 ValueChanged="@OnIncludeArchivedChanged"/>
</div>

<MudTable T="CategoryResponse"
          @ref="_table"
          @key="_tableVersion"
          ServerData="LoadServerDataAsync"
          RowsPerPage="50"
          Hover="true"
          Striped="true"
          Breakpoint="Breakpoint.Sm"
          Class="trackr-table">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Kind</MudTh>
        <MudTh>Priority</MudTh>
        <MudTh>Parent</MudTh>
        <MudTh Style="text-align: right;">Sort order</MudTh>
        <MudTh>Archived</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Kind">@(context.Kind?.ToString() ?? "")</MudTd>
        <MudTd DataLabel="Priority">
            @if (context.Kind == CategoryKind.Expense && context.Priority is not null)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="@ExpensePriorityFormat.GetChipVariant(context.Priority)"
                         Class="@ExpensePriorityFormat.GetChipClass(context.Priority)">
                    @ExpensePriorityFormat.GetLabel(context.Priority)
                </MudChip>
            }
            else
            {
                <text>—</text>
            }
        </MudTd>
        <MudTd DataLabel="Parent">@(context.Parent?.Name is { Length: > 0 } name ? name : "—")</MudTd>
        <MudTd DataLabel="Sort order" Style="text-align: right;" Class="font-mono-numbers">@context.SortOrder</MudTd>
        <MudTd DataLabel="Archived">
            @(context.IsArchived switch { true => "Yes", false => "No", _ => "" })
        </MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_mutation.IsPending || context.IsArchived == true)"
                           OnClick="@(() => OpenEditDialogAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
