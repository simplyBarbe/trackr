@using Trackr.Api.Models

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudStack Spacing="3">
                <MudTextField T="string"
                              Label="Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              MaxLength="100"
                              Immediate="true"
                              @bind-Value="_name" />

                <MudSelect T="CategoryKind"
                           Label="Kind"
                           Variant="Variant.Outlined"
                           Value="_kind"
                           ValueChanged="@OnKindChanged">
                    @foreach (var kind in Enum.GetValues<CategoryKind>())
                    {
                        <MudSelectItem T="CategoryKind" Value="@kind">@CategoryKindFormat.GetLabel(kind)</MudSelectItem>
                    }
                </MudSelect>

                @if (_kind == CategoryKind.Expense)
                {
                    <MudSelect T="ExpensePriority"
                               Label="Priority"
                               Variant="Variant.Outlined"
                               Value="_priority"
                               ValueChanged="@OnPriorityChanged">
                        @foreach (var priority in Enum.GetValues<ExpensePriority>())
                        {
                            <MudSelectItem T="ExpensePriority" Value="@priority">@ExpensePriorityFormat.GetLabel(priority)</MudSelectItem>
                        }
                    </MudSelect>
                }

                <MudSelect T="string"
                           Label="Parent"
                           Variant="Variant.Outlined"
                           Value="_parentId"
                           ValueChanged="@OnParentIdChanged">
                    <MudSelectItem T="string" Value="@("")">No parent</MudSelectItem>
                    @foreach (var category in ParentOptions)
                    {
                        <MudSelectItem T="string" Value="@(category.Id ?? "")">@category.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField T="int"
                                 Label="Sort order"
                                 Variant="Variant.Outlined"
                                 Min="0"
                                 @bind-Value="_sortOrder" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync">
            @SubmitText
        </MudButton>
    </DialogActions>
</MudDialog>
