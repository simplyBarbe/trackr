@page "/"

<PageTitle>Home</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">trackr</MudText>
<MudText Class="mb-4">Personal money tracking — foundation preview.</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else if (_health is not null)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">
        API @(_health.Status) — database @(_health.Database)
    </MudAlert>
}
else
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        API unreachable. Start the backend and ensure @(_apiBaseUrl) is correct.
    </MudAlert>
}

<MudText Typo="Typo.caption" Color="Color.Secondary">
    Client: @(_clientMode)
</MudText>
