@page "/"
@using frontend.Features.Accounts
@using Trackr.Api.Models

<PageTitle>Home</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">trackr</MudText>

@if (IsInitialLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}

<MudStack Spacing="2" Class="mb-4">
    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
        <MudButton OnClick="@(() => ApplyPresetAsync(DateRangePreset.ThisMonth))"
                   Color="@(_activePreset == DateRangePreset.ThisMonth ? Color.Primary : Color.Default)">
            This month
        </MudButton>
        <MudButton OnClick="@(() => ApplyPresetAsync(DateRangePreset.LastMonth))"
                   Color="@(_activePreset == DateRangePreset.LastMonth ? Color.Primary : Color.Default)">
            Last month
        </MudButton>
        <MudButton OnClick="@(() => ApplyPresetAsync(DateRangePreset.Last30Days))"
                   Color="@(_activePreset == DateRangePreset.Last30Days ? Color.Primary : Color.Default)">
            Last 30 days
        </MudButton>
        <MudButton OnClick="@(() => ApplyPresetAsync(DateRangePreset.YearToDate))"
                   Color="@(_activePreset == DateRangePreset.YearToDate ? Color.Primary : Color.Default)">
            Year to date
        </MudButton>
    </MudButtonGroup>

    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Style="flex-wrap: wrap;">
        <MudDatePicker Label="From"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width: 9rem;"
                       Date="_fromPicker"
                       DateChanged="OnFromPickerChanged"
                       Clearable="true" />
        <MudDatePicker Label="To"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width: 9rem;"
                       Date="_toPicker"
                       DateChanged="OnToPickerChanged"
                       Clearable="true" />
    </MudStack>
</MudStack>

@if (_summaryQuery.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_summaryQuery.Error</MudAlert>
}

<TransactionSummaryCards SummaryQuery="_summaryQuery" />

<MudText Typo="Typo.h5" Class="mb-3">Charts</MudText>

<MudGrid Class="mb-4" Spacing="2">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Expenses by category</MudText>
            @if (_expensesByCategoryQuery.IsError)
            {
                <MudText Color="Color.Error">@_expensesByCategoryQuery.Error</MudText>
            }
            else if (_categoryChartLabels.Length == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No expenses in this period.</MudText>
            }
            else
            {
                <MudChart T="double"
                          ChartType="ChartType.Donut"
                          ChartSeries="_categoryChartData.AsChartDataSet()"
                          ChartOptions="_donutChartOptions"
                          ChartLabels="_categoryChartLabels"
                          Width="100%"
                          Height="280px" />
                @if (_expensesByCategoryQuery.IsFetching || _summaryQuery.IsFetching)
                {
                    <MudProgressLinear Indeterminate="true" Class="mt-2" />
                }
            }
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Expenses by priority</MudText>
            @if (_summaryQuery.IsError)
            {
                <MudText Color="Color.Error">@_summaryQuery.Error</MudText>
            }
            else if (_priorityChartLabels.Length == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No expenses in this period.</MudText>
            }
            else
            {
                <MudChart T="double"
                          ChartType="ChartType.Pie"
                          ChartSeries="_priorityChartData.AsChartDataSet()"
                          ChartOptions="_priorityPieChartOptions"
                          ChartLabels="_priorityChartLabels"
                          Width="100%"
                          Height="280px" />
                @if (_summaryQuery.IsFetching)
                {
                    <MudProgressLinear Indeterminate="true" Class="mt-2" />
                }
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h5" Class="mb-3">Expenses by category</MudText>

@if (_expensesByCategoryQuery.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_expensesByCategoryQuery.Error</MudAlert>
}
else if (_expensesByCategoryQuery.HasData && _expensesByCategoryQuery.Data!.Count == 0)
{
    <MudText Class="mb-4" Color="Color.Secondary">No expenses in this period.</MudText>
}
else if (_expensesByCategoryQuery.HasData)
{
    var expenseTotal = GetCategoryExpenseTotal();
    <MudTable T="ExpenseByCategoryItem"
              Items="_expensesByCategoryQuery.Data"
              Hover="true"
              Dense="true"
              Class="mb-4"
              Loading="_expensesByCategoryQuery.IsFetching">
        <HeaderContent>
            <MudTh>Category</MudTh>
            <MudTh Style="text-align: right;">Amount</MudTh>
            <MudTh Style="text-align: right;">Share</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Category">@(context.CategoryName ?? "")</MudTd>
            <MudTd DataLabel="Amount" Style="text-align: right;">
                @MoneyFormat.Format(context.TotalAmount)
            </MudTd>
            <MudTd DataLabel="Share" Style="text-align: right;">
                @FormatPercent(context.TotalAmount ?? 0m, expenseTotal)
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudText Typo="Typo.h5" Class="mb-3">Balances</MudText>

@if (_accountsQuery.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_accountsQuery.Error</MudAlert>
}
else if (_accountsQuery.HasData && _accountsQuery.Data!.Count == 0)
{
    <MudText Class="mb-2">No accounts yet.</MudText>
    <MudButton Href="/accounts" Variant="Variant.Filled" Color="Color.Primary">
        Create an account
    </MudButton>
}
else if (_accountsQuery.HasData)
{
    <MudGrid Class="mb-4">
        @foreach (var account in _accountsQuery.Data!)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Style="@AccountCardStyles.GetCardStyle(account.Color)" Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@(account.Name ?? "")</MudText>
                        <MudText Typo="Typo.caption" Class="mb-2" Style="opacity: 0.85">
                            @(account.Type?.ToString() ?? "")
                        </MudText>
                        <MudText Typo="Typo.h5" Style="@AccountCardStyles.GetBalanceStyle(account)">
                            @FormatBalance(account)
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private readonly DonutChartOptions _donutChartOptions = new() { ShowLegend = true };
}
