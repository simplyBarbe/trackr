@using Trackr.Api.Models
@using frontend.Features.Shared

@if (_tableError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_tableError</MudAlert>
}

<MudTable T="TransactionResponse"
          @ref="_table"
          ServerData="LoadServerDataAsync"
          Hover="true"
          Striped="true"
          Breakpoint="Breakpoint.Sm"
          Class="trackr-table">
    <HeaderContent>
        <MudTh>Date</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Account</MudTh>
        <MudTh>Category</MudTh>
        <MudTh>Priority</MudTh>
        <MudTh Style="text-align: right;">Amount</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Created</MudTh>
        <MudTh Style="width: 4rem;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Date">@FormatOccurredOn(context.OccurredOn)</MudTd>
        <MudTd DataLabel="Type">@(context.Type?.ToString() ?? "")</MudTd>
        <MudTd DataLabel="Account">@FormatAccount(context)</MudTd>
        <MudTd DataLabel="Category">@(string.IsNullOrEmpty(context.CategoryName) ? "—" : context.CategoryName)</MudTd>
        <MudTd DataLabel="Priority">
            @if (context.Type == TransactionType.Expense && context.Priority is not null)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="@ExpensePriorityFormat.GetChipVariant(context.Priority)"
                         Class="@ExpensePriorityFormat.GetChipClass(context.Priority)">
                    @ExpensePriorityFormat.GetLabel(context.Priority)
                </MudChip>
            }
            else
            {
                <text>—</text>
            }
        </MudTd>
        <MudTd DataLabel="Amount" Style="text-align: right;" Class="font-mono-numbers">
            @FormatAmount(context.Amount)
        </MudTd>
        <MudTd DataLabel="Description">
            @if (!string.IsNullOrEmpty(context.RecurringTransactionId))
            {
                <MudTooltip Text="Created from a recurring rule">
                    <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Size="Size.Small" Class="me-1 mud-text-secondary" />
                </MudTooltip>
            }
            @(context.Description ?? "")
        </MudTd>
        <MudTd DataLabel="Created">@FormatCreatedAt(context.CreatedAt)</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(Saving || !CanEdit)"
                           OnClick="@(() => OnEdit.InvokeAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
