@page "/transactions"
@using Trackr.Api.Models

<PageTitle>Transactions</PageTitle>

<div class="trackr-page-header">
    <div>
        <span class="trackr-page-badge">Ledger</span>
        <MudText Typo="Typo.h4" Style="font-weight: 600; letter-spacing: -0.02em;">Transactions</MudText>
    </div>
    <div class="d-flex gap-2">
        <MudButton Color="Color.Secondary"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Download"
                   Disabled="@_exporting"
                   OnClick="ExportCsvAsync">
            @if (_exporting)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Exporting...</MudText>
            }
            else
            {
                <text>Export CSV</text>
            }
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@(_saving || !CanMutate)"
                   OnClick="OpenCreateDialogAsync">
            New transaction
        </MudButton>
    </div>
</div>

@if (_accountsLoading || _categoriesLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" Color="Color.Primary" />
}

<div class="trackr-toolbar mb-4">
    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Account"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_accountIdFilter"
                   ValueChanged="@OnAccountFilterChanged"
                   Disabled="@(_accountsLoading || _accountsError is not null)"
                   Clearable="true">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @foreach (var account in _accounts)
            {
                <MudSelectItem T="string" Value="@(account.Id ?? "")">@account.Name</MudSelectItem>
            }
        </MudSelect>
    </div>
    @if (_accountsError is not null)
    {
        <MudText Typo="Typo.caption" Color="Color.Error">@_accountsError</MudText>
    }

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Category"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_categoryIdFilter"
                   ValueChanged="@OnCategoryFilterChanged"
                   Disabled="@(_categoriesLoading || _categoriesError is not null)"
                   Clearable="true">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @foreach (var category in _categories)
            {
                <MudSelectItem T="string" Value="@(category.Id ?? "")">@category.Name</MudSelectItem>
            }
        </MudSelect>
    </div>
    @if (_categoriesError is not null)
    {
        <MudText Typo="Typo.caption" Color="Color.Error">@_categoriesError</MudText>
    }

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Type"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_typeFilter"
                   ValueChanged="@OnTypeFilterChanged">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Income")">Income</MudSelectItem>
            <MudSelectItem T="string" Value="@("Expense")">Expense</MudSelectItem>
            <MudSelectItem T="string" Value="@("Transfer")">Transfer</MudSelectItem>
        </MudSelect>
    </div>

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Priority"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_priorityFilter"
                   ValueChanged="@OnPriorityFilterChanged"
                   Clearable="true">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Essential")">Essential</MudSelectItem>
            <MudSelectItem T="string" Value="@("Important")">Important</MudSelectItem>
            <MudSelectItem T="string" Value="@("Discretionary")">Discretionary</MudSelectItem>
        </MudSelect>
    </div>

    <div class="trackr-filter-field">
        <MudDatePicker Label="From"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Date="_fromPicker"
                       DateChanged="OnFromFilterCommitted"
                       Clearable="true" />
    </div>
    <div class="trackr-filter-field">
        <MudDatePicker Label="To"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Date="_toPicker"
                       DateChanged="OnToFilterCommitted"
                       Clearable="true" />
    </div>
</div>

<TransactionsSummarySection Filters="_listFilters" RefreshVersion="_refreshVersion" />

<TransactionsTableSection Filters="_listFilters"
                          RefreshVersion="_refreshVersion"
                          CanEdit="CanMutate"
                          Saving="_saving"
                          OnEdit="OpenEditDialogAsync" />
