@page "/transactions"
@using Trackr.Api.Models
@using frontend.Features.Shared

<PageTitle>Transactions</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Transactions</MudText>

@if (_accountsQuery.IsLoading || _categoriesQuery.IsLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}

@if (_query.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_query.Error</MudAlert>
}

<MudStack Spacing="3" Class="mb-4" AlignItems="AlignItems.Start">
    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               Disabled="@(_mutation.IsPending || !CanMutate)"
               OnClick="OpenCreateDialogAsync">
        New transaction
    </MudButton>

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
            <MudStack Spacing="0">
                <MudSelect T="string"
                           Label="Account"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true"
                           Value="_accountIdFilter"
                           ValueChanged="@OnAccountFilterChanged"
                           Disabled="@(_accountsQuery.IsLoading || _accountsQuery.IsError)"
                           Clearable="true">
                    <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
                    @if (_accountsQuery.HasData)
                    {
                        @foreach (var account in _accountsQuery.Data!)
                        {
                            <MudSelectItem T="string" Value="@(account.Id ?? "")">@account.Name</MudSelectItem>
                        }
                    }
                </MudSelect>
                @if (_accountsQuery.IsError)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@_accountsQuery.Error</MudText>
                }
            </MudStack>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
            <MudStack Spacing="0">
                <MudSelect T="string"
                           Label="Category"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true"
                           Value="_categoryIdFilter"
                           ValueChanged="@OnCategoryFilterChanged"
                           Disabled="@(_categoriesQuery.IsLoading || _categoriesQuery.IsError)"
                           Clearable="true">
                    <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
                    @if (_categoriesQuery.HasData)
                    {
                        @foreach (var category in _categoriesQuery.Data!)
                        {
                            <MudSelectItem T="string" Value="@(category.Id ?? "")">@category.Name</MudSelectItem>
                        }
                    }
                </MudSelect>
                @if (_categoriesQuery.IsError)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@_categoriesQuery.Error</MudText>
                }
            </MudStack>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
            <MudSelect T="string"
                       Label="Type"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       FullWidth="true"
                       Value="_typeFilter"
                       ValueChanged="@OnTypeFilterChanged">
                <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
                <MudSelectItem T="string" Value="@("Income")">Income</MudSelectItem>
                <MudSelectItem T="string" Value="@("Expense")">Expense</MudSelectItem>
                <MudSelectItem T="string" Value="@("Transfer")">Transfer</MudSelectItem>
            </MudSelect>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
            <MudSelect T="string"
                       Label="Priority"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       FullWidth="true"
                       Value="_priorityFilter"
                       ValueChanged="@OnPriorityFilterChanged"
                       Clearable="true">
                <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
                <MudSelectItem T="string" Value="@("Essential")">Essential</MudSelectItem>
                <MudSelectItem T="string" Value="@("Important")">Important</MudSelectItem>
                <MudSelectItem T="string" Value="@("Discretionary")">Discretionary</MudSelectItem>
            </MudSelect>
        </MudItem>

        <MudItem xs="12" sm="6">
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Style="flex-wrap: nowrap;">
                <MudDatePicker Label="From"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Style="min-width: 9rem;"
                               Date="_fromPicker"
                               DateChanged="@OnFromPickerChanged"
                               Clearable="true" />
                <MudDatePicker Label="To"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Style="min-width: 9rem;"
                               Date="_toPicker"
                               DateChanged="@OnToPickerChanged"
                               Clearable="true" />
            </MudStack>
        </MudItem>
    </MudGrid>
</MudStack>

@if (_summaryQuery.IsError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_summaryQuery.Error</MudAlert>
}

<TransactionSummaryCards SummaryQuery="_summaryQuery" />

<MudTable T="TransactionResponse"
          @ref="_table"
          @key="_tableVersion"
          ServerData="LoadServerDataAsync"
          RowsPerPage="50"
          Hover="true"
          Striped="true"
          Breakpoint="Breakpoint.Sm"
          Loading="_query.IsFetching">
    <HeaderContent>
        <MudTh>Date</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Account</MudTh>
        <MudTh>Category</MudTh>
        <MudTh>Priority</MudTh>
        <MudTh>Amount</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Created</MudTh>
        <MudTh Style="width: 4rem;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Date">@FormatOccurredOn(context.OccurredOn)</MudTd>
        <MudTd DataLabel="Type">@(context.Type?.ToString() ?? "")</MudTd>
        <MudTd DataLabel="Account">@FormatAccount(context)</MudTd>
        <MudTd DataLabel="Category">@(string.IsNullOrEmpty(context.CategoryName) ? "—" : context.CategoryName)</MudTd>
        <MudTd DataLabel="Priority">
            @if (context.Type == TransactionType.Expense && context.Priority is not null)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@ExpensePriorityFormat.GetChipColor(context.Priority)">
                    @ExpensePriorityFormat.GetLabel(context.Priority)
                </MudChip>
            }
            else
            {
                <text>—</text>
            }
        </MudTd>
        <MudTd DataLabel="Amount">@FormatAmount(context.Amount)</MudTd>
        <MudTd DataLabel="Description">@(context.Description ?? "")</MudTd>
        <MudTd DataLabel="Created">@FormatCreatedAt(context.CreatedAt)</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_mutation.IsPending || !CanMutate)"
                           OnClick="@(() => OpenEditDialogAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
