@page "/transactions"
@using Trackr.Api.Models
@using frontend.Features.Shared

<PageTitle>Transactions</PageTitle>

<div class="trackr-page-header">
    <div>
        <span class="trackr-page-badge">Ledger</span>
        <MudText Typo="Typo.h4" Style="font-weight: 600; letter-spacing: -0.02em;">Transactions</MudText>
    </div>
    <div class="d-flex gap-2">
        <MudButton Color="Color.Secondary"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Download"
                   Disabled="@_exporting"
                   OnClick="ExportCsvAsync">
            @if (_exporting)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Exporting...</MudText>
            }
            else
            {
                <text>Export CSV</text>
            }
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@(_saving || !CanMutate)"
                   OnClick="OpenCreateDialogAsync">
            New transaction
        </MudButton>
    </div>
</div>

@if (_accountsLoading || _categoriesLoading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" Color="Color.Primary" />
}

<div class="trackr-toolbar mb-4">
    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Account"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_accountIdFilter"
                   ValueChanged="@OnAccountFilterChanged"
                   Disabled="@(_accountsLoading || _accountsError is not null)"
                   Clearable="true">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @foreach (var account in _accounts)
            {
                <MudSelectItem T="string" Value="@(account.Id ?? "")">@account.Name</MudSelectItem>
            }
        </MudSelect>
    </div>
    @if (_accountsError is not null)
    {
        <MudText Typo="Typo.caption" Color="Color.Error">@_accountsError</MudText>
    }

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Type"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_typeFilter"
                   ValueChanged="@OnTypeFilterChanged">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @foreach (var type in Enum.GetValues<TransactionType>())
            {
                <MudSelectItem T="string" Value="@ApiEnumWire.GetValue(type)">@TransactionTypeFormat.GetLabel(type)</MudSelectItem>
            }
        </MudSelect>
    </div>

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Category"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_categoryIdFilter"
                   ValueChanged="@OnCategoryFilterChanged"
                   Disabled="@IsCategoryFilterDisabled"
                   Clearable="true">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @foreach (var category in FilterCategoryOptions)
            {
                <MudSelectItem T="string" Value="@(category.Id ?? "")">@category.Name</MudSelectItem>
            }
        </MudSelect>
    </div>
    @if (_categoriesError is not null)
    {
        <MudText Typo="Typo.caption" Color="Color.Error">@_categoriesError</MudText>
    }

    <div class="trackr-filter-field">
        <MudSelect T="string"
                   Label="Priority"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="_priorityFilter"
                   ValueChanged="@OnPriorityFilterChanged"
                   Clearable="true">
            <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
            @foreach (var priority in Enum.GetValues<ExpensePriority>())
            {
                <MudSelectItem T="string" Value="@ApiEnumWire.GetValue(priority)">@ExpensePriorityFormat.GetLabel(priority)</MudSelectItem>
            }
        </MudSelect>
    </div>

    <div class="trackr-filter-field">
        <MudDatePicker Label="From"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Date="_fromPicker"
                       DateChanged="OnFromFilterCommitted"
                       Clearable="true" />
    </div>
    <div class="trackr-filter-field">
        <MudDatePicker Label="To"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Date="_toPicker"
                       DateChanged="OnToFilterCommitted"
                       Clearable="true" />
    </div>
</div>

@if (_summaryError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_summaryError</MudAlert>
}

<TransactionSummaryCards Summary="_summary" IsInitialLoading="_summaryInitialLoading" />

@if (_tableError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_tableError</MudAlert>
}

<MudTable T="TransactionResponse"
          @ref="_table"
          ServerData="LoadServerDataAsync"
          Hover="true"
          Striped="true"
          Breakpoint="Breakpoint.Sm"
          Class="trackr-table">
    <HeaderContent>
        <MudTh>Date</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Account</MudTh>
        <MudTh>Category</MudTh>
        <MudTh>Priority</MudTh>
        <MudTh Style="text-align: right;">Amount</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Created</MudTh>
        <MudTh Style="width: 4rem;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Date">@FormatOccurredOn(context.OccurredOn)</MudTd>
        <MudTd DataLabel="Type">@(context.Type is { } type ? TransactionTypeFormat.GetLabel(type) : "")</MudTd>
        <MudTd DataLabel="Account">@FormatAccount(context)</MudTd>
        <MudTd DataLabel="Category">@(string.IsNullOrEmpty(context.CategoryName) ? "—" : context.CategoryName)</MudTd>
        <MudTd DataLabel="Priority">
            @if (context.Type == TransactionType.Expense && context.Priority is not null)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="@ExpensePriorityFormat.GetChipVariant(context.Priority)"
                         Class="@ExpensePriorityFormat.GetChipClass(context.Priority)">
                    @ExpensePriorityFormat.GetLabel(context.Priority)
                </MudChip>
            }
            else
            {
                <text>—</text>
            }
        </MudTd>
        <MudTd DataLabel="Amount" Style="text-align: right;" Class="font-mono-numbers">
            @FormatAmount(context.Amount)
        </MudTd>
        <MudTd DataLabel="Description">
            @if (!string.IsNullOrEmpty(context.RecurringTransactionId))
            {
                <MudTooltip Text="Created from a recurring rule">
                    <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Size="Size.Small" Class="me-1 mud-text-secondary" />
                </MudTooltip>
            }
            @(context.Description ?? "")
        </MudTd>
        <MudTd DataLabel="Created">@FormatCreatedAt(context.CreatedAt)</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_saving || !CanMutate)"
                           OnClick="@(() => OpenEditDialogAsync(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
